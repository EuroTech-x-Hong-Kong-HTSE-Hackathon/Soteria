# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Camera / perception ---
CAMERA_INDEX=0
YOLO_POSE_MODEL=yolo11n-pose.pt        # yolov8n-pose.pt also works; ultralytics auto-downloads
FALL_CONFIDENCE_THRESHOLD=0.6
VERIFICATION_TIMER_SECONDS=20          # wait before escalating, to cut false positives

# --- Agent (Ollama, local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2                   # small local model; swap for the best small one available

# --- Alerts (Telegram) ---
ALERT_CHANNEL=telegram                 # telegram | twilio
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Alerts (Twilio, optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# --- Scam-call stretch ---
WHISPER_MODEL=base
