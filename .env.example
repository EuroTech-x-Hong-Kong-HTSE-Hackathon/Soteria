# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Camera / perception ---
CAMERA_INDEX=0
POSE_MODEL=yolo11n-pose.pt                              # default fall detector: Ultralytics YOLO-pose (auto-downloaded)
FALL_DETECTOR_REPO=melihuzunoglu/human-fall-detection   # legacy "fall_box" model (bounding-box classifier)
FALL_DETECTOR_FILENAME=best.pt                          # weights file inside the HF repo
FALL_CONFIDENCE_THRESHOLD=0.6
ENABLED_DETECTORS=["fall"]                              # JSON list; future: ["fall","intruder"]
SHOW_PERCEPTION_WINDOW=true
SHOW_DETECTOR_OVERLAY=false                             # YOLO-style colored boxes + class labels (slower)
PIPELINE_MIN_CONFIRM_SECONDS=1.0                        # candidate must persist this long before going to the agent
PIPELINE_RECOVERY_SECONDS=1.5                           # detector must stay sub-threshold this long before "recovery" fires (debounces transient drops)
VERIFICATION_TIMER_SECONDS=20                           # agent grace period before escalating

# --- Agent (Ollama, local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2                   # small local model; swap for the best small one available

# --- Alerts (Telegram) ---
ALERT_CHANNEL=telegram                 # telegram | twilio
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Alerts (Twilio, optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# --- Scam-call stretch ---
WHISPER_MODEL=base
SCAM_CONFIDENCE_THRESHOLD=0.7          # alert only when scam confidence >= this
